# Sinh các giá trị bí mật bằng: python scripts/genkey.py

# AES-256 master key (base64, 32 bytes). Mất key này = mất quyền giải mã bot.
MASTER_KEY_B64=

# Secret ký JWT legacy (chỉ để đọc flow cũ nếu còn cần). Product mới không gửi JWT cho khách.
JWT_SECRET=

# Khoá admin gọi các endpoint /api/v1/admin/* (header: X-Admin-Key)
ADMIN_API_KEY=

# Thư mục chứa bot gốc (chưa mã hóa). Tương đối so với token-bot/
SOURCE_BOT_DIR=../bot-trading

# Nơi lưu bot đã mã hóa
ENCRYPTED_BOT_DIR=./var/encrypted

# SQLite (sẽ tự tạo thư mục)
DATABASE_URL=sqlite:///./var/token_bot.db

# TTL token mặc định (giây). 86400 = 1 ngày
TOKEN_DEFAULT_TTL_SEC=86400

# Production để 0: không cho endpoint cũ phát JWT mới. Đối tác cấp mã qua backend product token.
ENABLE_LEGACY_JWT_TOKENS=0

# Bind HTTP
HOST=0.0.0.0
PORT=8090

# 1 = cho phép admin GET /admin/bots/{id}/decrypted (debug). Production để 0
ENABLE_DEBUG_DECRYPT=0

# Telegram bot quản trị (admin cấp quyền partner; partner cấp token end-user)
# Lấy token từ @BotFather. KHÔNG dùng cùng token với hubbot Spider AI.
TELEGRAM_BOT_TOKEN=

# Danh sách Telegram user_id của admin, ngăn cách dấu phẩy. Vd: 12345,67890
# Gửi /whoami cho bot để biết Telegram ID của mình
TG_ADMIN_USER_IDS=

# Redis chỉ còn dùng cho token legacy và tác vụ phụ. Product activation code do backend Postgres quản lý.
REDIS_URL=

# TTL gracetime sau khi token expire (giây) — key Redis vẫn giữ state để backend phân biệt
# "revoked/locked" vs "unknown". Mặc định 7 ngày.
REDIS_STATE_GRACE_SEC=604800

# Backend chính để token-bot gọi internal issue/revoke product activation code.
# Trong Docker Compose đặt override thành http://cntx-lab:8001.
BACKEND_URL=

# Phải trùng với PARTNER_USER_INTERNAL_KEY ở backend.
BACKEND_INTERNAL_KEY=

# Công nợ đối tác theo tuần, reset công thức theo tháng.
PARTNER_WEEKLY_BILLING_ENABLED=1
PARTNER_BILLING_TIMEZONE=Asia/Ho_Chi_Minh
# Chu kỳ tính phí rolling theo ngày. User kích hoạt ngày 29 thì không bị reset ở cuối tháng lịch.
PARTNER_BILLING_CYCLE_DAYS=30
# Python weekday: Monday=0 ... Sunday=6.
PARTNER_BILLING_NOTICE_WEEKDAY=6
PARTNER_BILLING_NOTICE_HOUR=18
PARTNER_USER_FEE_USD=15
PARTNER_SUPPORT_BLOCK_SIZE=15
PARTNER_SUPPORT_FEE_USD=150
PARTNER_INFRA_FEE_USD=100
