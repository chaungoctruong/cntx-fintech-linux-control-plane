# MT5 runner process talks to Linux control plane over HTTP + Redis.
# This file is for external Windows runner deployment or local stub testing.
# Do not use Docker DNS names such as `redis` from a Windows VPS.

APP_ENV=development

# Control plane URL the runner will call for register/heartbeat/events/bundle/package.
# Use https only when the certificate is trusted by Python on the runner host.
BACKEND_URL=http://<linux-control-plane-host>:8001
RUNNER_CONTROL_PLANE_URL=http://<linux-control-plane-host>:8001
BACKEND_API_KEY=change-me

# Current Windows runner repo reads REDIS_URL and BOT_COMMAND_QUEUE_REDIS_URL.
# Use a routable private/public Redis host with auth; do not use redis://redis:6379/0.
REDIS_URL=redis://:<password>@<linux-or-redis-host>:6379/0
BOT_COMMAND_QUEUE_REDIS_URL=redis://:<password>@<linux-or-redis-host>:6379/0

# Linux control-plane/local stub compatibility. Current Windows runner does not read this.
REDIS_WRITE_URL=redis://:<password>@<linux-or-redis-host>:6379/0

# Identity for this runner node. Current Windows runner uses NODE_ID.
NODE_ID=runner-win-02
RUNNER_ID=runner-win-02

# Legacy local stub identity, kept only for backend_ai scripts/run_mt5_runner_stub.py.
MT5_RUNNER_ID=runner-win-02
MT5_RUNNER_SLOT_ID=slot-01

# Shared crypto secret only needed if runner imports backend settings locally.
APP_SECRET_KEY=CHANGE_ME
