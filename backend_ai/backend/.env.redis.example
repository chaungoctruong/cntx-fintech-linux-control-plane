# Redis master (required for BLPOP, LPUSH, XADD, XACK, consumer groups, streams)
REDIS_WRITE_URL=redis://cntx_backend:CHANGE_ME@redis-master.internal:6379/0

# Optional read replica for GET/TTL/EXISTS-style paths only (leave empty to use master for reads too)
# REDIS_READ_URL=redis://cntx_backend:CHANGE_ME@redis-replica.internal:6379/0

# Legacy; used only if REDIS_WRITE_URL and the URLs below are all empty
# REDIS_URL=redis://127.0.0.1:6379/0

# Optional overrides (empty = inherit REDIS_WRITE_URL)
# BOT_COMMAND_QUEUE_REDIS_URL=
# MT5_EVENT_REDIS_URL=
# MT5_LOG_REDIS_URL=

# Internal LIST queue for bot commands (must NOT be stream:...)
BOT_COMMAND_QUEUE_KEY=cmd:mt5:commands

# Streams (separate from LIST queue)
# MT5_COMMAND_STREAM_KEY=stream:mt5:commands
# MT5_EVENT_STREAM_KEY=stream:mt5:events
# MT5_LOG_STREAM_KEY=stream:mt5:logs
