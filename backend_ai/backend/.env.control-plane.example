# ACTIVE BASELINE
# Day la env example uu tien cho Linux backend / control plane MT5.
# Linux backend chi dieu phoi, khong duoc place order truc tiep vao MT5.

APP_ENV=production
SERVICE_MODE=local
DRY_RUN=0

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
PUBLIC_BASE_URL=https://your-domain.example
BACKEND_URL=https://your-domain.example
RUNNER_CONTROL_PLANE_URL=https://your-domain.example

APP_SECRET_KEY=CHANGE_ME
BACKEND_API_KEY=CHANGE_ME

# Optional bridge to lane 2 `backend-ctrader`.
# Keep empty if Mini App chua mo cTrader flow.
BROKER_API_CTRADER_BASE_URL=https://ctrader-api.your-domain.example
BROKER_API_CTRADER_SHARED_KEY=CHANGE_ME
BROKER_API_CTRADER_TIMEOUT_SEC=15

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_MINI_APP_SHORT_NAME=
ADMIN_TELEGRAM_IDS=
MINIAPP_FULL_ACCESS_TELEGRAM_IDS=

# Start/stop control-plane guard. 60 = 1 minute.
BOT_CONTROL_COOLDOWN_SEC=60

AI_PROVIDER=ollama
AI_CHAT_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
AI_CHAT_OLLAMA_USE_GEMINI_FOR_SEARCH=false
AI_CHAT_OLLAMA_USE_GEMINI_FOR_COMPLEX=false
AI_LOCAL_MAX_CONCURRENT=1
AI_LOCAL_QUEUE_WAIT_SEC=0.5
AI_CHAT_TIMEOUT_SEC=20
AI_CHAT_IMMEDIATE_FALLBACK_ENABLED=true
# true = user waits for local Qwen on cache miss; false = cache/learned answer first, then queue background preparation.
AI_CHAT_SYNC_GENERATION_ENABLED=true
AI_CHAT_LEARNED_DIRECT_REPLY_ENABLED=true
AI_CHAT_LEARNED_DIRECT_REPLY_MIN_SCORE=0.76
AI_CHAT_DB_MEMORY_ENABLED=true
AI_CHAT_DB_CACHE_ENABLED=true
# 0 = keep PostgreSQL AI learning memory available permanently.
AI_CHAT_DB_CACHE_TTL_SEC=0
AI_CHAT_DB_GLOBAL_LEARNING_ENABLED=true
AI_CHAT_DB_LEARNED_CONTEXT_LIMIT=3
AI_CHAT_DB_LEARNED_SIMILARITY_THRESHOLD=0.42
AI_PLATFORM_KNOWLEDGE_ENABLED=true
AI_PLATFORM_KNOWLEDGE_MAX_CHUNKS=4
AI_PLATFORM_KNOWLEDGE_MIN_TRUST_LEVEL=40
AI_PLATFORM_KNOWLEDGE_VECTOR_ENABLED=false
AI_PLATFORM_KNOWLEDGE_EMBEDDING_PROVIDER=sentence_transformers
AI_PLATFORM_KNOWLEDGE_EMBEDDING_MODEL=BAAI/bge-m3
AI_PLATFORM_KNOWLEDGE_EMBEDDING_DEVICE=cpu
AI_PLATFORM_KNOWLEDGE_PGVECTOR_DIM=1024
AI_PLATFORM_KNOWLEDGE_VECTOR_TOP_K=8
AI_PLATFORM_KNOWLEDGE_VECTOR_MIN_SCORE=0.45
AI_PLATFORM_KNOWLEDGE_VECTOR_SCAN_LIMIT=240
AI_CONTINUOUS_LEARNING_ENABLED=false
# 24/7 curated RAG ingest. 3600 = refresh approved sources about once per hour.
AI_CONTINUOUS_LEARNING_INTERVAL_SEC=3600
AI_CONTINUOUS_LEARNING_MANIFEST_PATH=backend_ai/backend/ops/ai/knowledge_sources/continuous_internet_sources.json
AI_CONTINUOUS_LEARNING_ALLOWED_DOMAINS=["ai.google.dev","developers.google.com","docs.github.com","redis.io","www.postgresql.org","fastapi.tiangolo.com","docs.sqlalchemy.org","alembic.sqlalchemy.org","ollama.com","raw.githubusercontent.com","pydantic.dev","www.psycopg.org","qwen.readthedocs.io","www.sbert.net","www.python-httpx.org"]
AI_CONTINUOUS_LEARNING_REDIS_QUEUE=ai:knowledge:ingest:requests
AI_CONTINUOUS_LEARNING_MAX_JOBS_PER_TICK=5
AI_TRAINING_CAPTURE_ENABLED=true
AI_TRAINING_MIN_PROMPT_CHARS=6
AI_TRAINING_MAX_PROMPT_CHARS=1800
AI_TRAINING_MAX_COMPLETION_CHARS=5000
AI_TRAINING_DEFAULT_EXPORT_LIMIT=1000
AI_TRAINING_EXPORT_DIR=ops/ai/training_exports
# Legacy Ollama fallback only: OLLAMA_MODEL -> AI_MODEL -> qwen3:8b.
AI_MODEL=qwen3:8b

# Gemini is budget-scoped to the shared morning news digest.
# Chat/runtime fallback stays off unless explicitly re-enabled.
AI_CARE_CAMPAIGN_ENABLED=true
AI_CARE_DRY_RUN=false
AI_CARE_INCLUDE_NEWS=true
AI_CARE_NEWS_USE_GEMINI=true
AI_CARE_MORNING_HOUR=6
AI_CARE_MORNING_WINDOW_MIN=60
AI_CARE_NEWS_MAX_LINKS=10
AI_CARE_NEWS_CACHE_TTL_SEC=1800
AI_CARE_NEWS_STALE_HOURS=720
AI_CARE_DIGEST_CACHE_TTL_SEC=86400
AI_CARE_EXTRA_TELEGRAM_IDS=

DB_MODE=postgres
POSTGRES_USER=truong_admin
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=6432
POSTGRES_DB=spider_ai_saas
# Connection budget: total ~= nodes x PM2 processes x POSTGRES_POOL_MAX + reserved.
POSTGRES_POOL_MIN=3
POSTGRES_POOL_MAX=15

# Production Redis must require auth. Replace CHANGE_ME with a secret-managed
# value before deployment.
REDIS_URL=redis://default:CHANGE_ME@127.0.0.1:6379/0
REDIS_WRITE_URL=redis://default:CHANGE_ME@127.0.0.1:6379/0
REDIS_READ_URL=

STARTUP_SINGLETON_ENABLED=true
BACKGROUND_SINGLETON_ENABLED=true
CONTROL_PLANE_RECONCILE_INTERVAL_SEC=30
CONTROL_PLANE_RUNNER_STALE_SEC=180
CONTROL_PLANE_DEPLOYMENT_STALE_SEC=180
ACCOUNT_RUNTIME_START_GUARD_STALE_SEC=180
RUNNER_HEARTBEAT_WRITE_THROTTLE_SEC=5
RUNNER_CATALOG_SYNC_TTL_SEC=600
MINIAPP_DASHBOARD_CACHE_TTL_SEC=5
SCHEDULER_RUNNER_QUEUE_BACKLOG_THRESHOLD=20
CONFIG_RESTART_COMMAND_TIMEOUT_SEC=180
CONFIG_HOT_UPDATE_COMMAND_TIMEOUT_SEC=180
COMMAND_DELIVERY_PROCESSING_REQUEUE_ENABLED=true
COMMAND_DELIVERY_PROCESSING_REQUEUE_TIMEOUT_SEC=180
COMMAND_DELIVERY_PROCESSING_REQUEUE_BATCH_SIZE=100
COMMAND_DELIVERY_PROCESSING_REQUEUE_SCAN_LIMIT=500
CONTROL_PLANE_EVENT_CONSUMER_ENABLED=true
CONTROL_PLANE_EVENT_CONSUMER_GROUP=control-plane-event-audit

# Khong dua CTRADER_* vao baseline active.
# Neu can nghien cuu lai nhanh adapter legacy, xem `.env.connect.example`.
