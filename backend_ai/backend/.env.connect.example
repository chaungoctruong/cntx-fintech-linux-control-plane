# ARCHIVE ONLY
# Day la env example cho huong broker/API adapter legacy dang bi freeze.
# Khong dung file nay lam baseline cho Linux control plane MT5 dang active.
# Huong active nen bat dau tu `.env.control-plane.example`.

# External WEB B ↔ Telegram-safe connect (legacy adapter only)
WEB_B_SHARED_SECRET=
WEB_B_CONNECT_URL=https://your-web-b.example.com/connect
TELEGRAM_BOT_USERNAME=your_bot
# If empty, telegram_deep_link in /session uses https://t.me/<user>?startapp=...
TELEGRAM_MINI_APP_SHORT_NAME=
CONNECT_SESSION_TTL_SECONDS=600
CONNECT_RETURN_STARTAPP=bot_connected

# Frozen cTrader adapter example
# Day la app credentials cua he thong legacy. User cuoi khong can tu tao API key.
CTRADER_CLIENT_ID=
CTRADER_CLIENT_SECRET=
CTRADER_REDIRECT_URI=https://your-domain.example/api/v2/connect/ctrader/callback
CTRADER_AUTH_URL=https://id.ctrader.com/my/settings/openapi/grantingaccess/
CTRADER_TOKEN_URL=https://openapi.ctrader.com/apps/token
CTRADER_PRODUCT=web
CTRADER_DEFAULT_SCOPE=accounts
CTRADER_DEFAULT_BROKER_LABEL=ic_markets
CTRADER_HOST=live
CTRADER_OAUTH_STATE_TTL_SEC=600
CTRADER_RUNNER_POLL_SEC=5
CTRADER_TOKEN_REFRESH_GRACE_SEC=300
CTRADER_ACCOUNTS_PROBE_TIMEOUT_SEC=20
CTRADER_MARKET_DATA_TIMEOUT_SEC=20
CTRADER_ORDER_TIMEOUT_SEC=25
CTRADER_LIVE_EXECUTION_ENABLED=false
