color up_color = i_chu_de == "Bộ màu cho nền đen" ? color.rgb(0, 225, 255) : #55ffda
color dn_color = i_chu_de == "Bộ màu cho nền đen" ? color.rgb(255, 255, 0) : #8c5bff

//pivotLenLiq = input.int(4, "Pivot Length", group = "General Configuration", display = display.none)
mssOffset = 5//input.int(5, "MSS Swing Length", group = "General Configuration")
chartTfSeconds = timeframe.in_seconds()
higherTimeframe = chartTfSeconds < timeframe.in_seconds("10") ? "10" : chartTfSeconds < timeframe.in_seconds("60") ? "60" : chartTfSeconds < timeframe.in_seconds("240") ? "240" : chartTfSeconds < timeframe.in_seconds("D") ? "D" : chartTfSeconds < timeframe.in_seconds("W") ? "W" : chartTfSeconds < timeframe.in_seconds("M") ? "M" : "12M"
breakoutMethod = "Wick"//input.string("Wick", "Breakout Method", options = ["Close", "Wick"], group = "General Configuration")
entryMethod = "Classic"//input.string("Classic", "Entry Method", options = ["Classic", "Adaptive"], group = "General Configuration", tooltip = "The entry method for the indicator to use. Try changing this setting if you are getting poor results.")
dbgTPSLVersion = "Default"//input.string("Default", "TP / SL Layout", options = ["Default", "Alternative"], group = "General Configuration")
dbgLabelSize = "Normal"//DEBUG ? input.string("Small", "[DBG] Label Size", ["Normal", "Small", "Tiny"], group = "General Configuration") : "Normal"
lblSize = (dbgLabelSize == "Small" ? size.small : dbgLabelSize == "Normal" ? size.normal : size.tiny)

showHL = false//input.bool(false, "Show Liquidity Zones", inline = "3", group = "General Configuration")
showLiqGrabs = true//input.bool(true, "Liq Grabs", inline = "3", group = "General Configuration")
showTPSL = true//input.bool(true, "TP / SL", inline = "3", group = "General Configuration")

tpslMethod = "Fixed"//input.string("Fixed", "TP / SL Method", options = ["Dynamic", "Fixed"], group = "TP / SL")
riskAmount = "Lowest"//input.string("Lowest", "Risk", options = ["Highest", "High", "Normal", "Low", "Lowest"], group = "TP / SL", tooltip = "The risk amount when Dynamic TP / SL method is selected.\n\nDifferent assets may have different volatility so changing this setting may result in change of performance of the indicator.")
customSLATRMult = 6.5//DEBUG ? input.float(6.5, "Custom Risk Mult", group = "TP / SL") : 6.5
tpPercent = 0.2//input.float(0.2, "Take Profit %", group = "TP / SL")
slPercent = 0.3//input.float(0.3, "Stop Loss %", group = "TP / SL")

RR = 0.9//DEBUG ? input.float(0.9, "Risk:Reward Ratio", group = "Debug") : 0.9

slATRMult = riskAmount == "Highest" ? 10 : riskAmount == "High" ? 6.5 : riskAmount == "Normal" ? 5.5 : riskAmount == "Low" ? 3.5 : riskAmount == "Lowest" ? 1.15 : customSLATRMult

backtestDisplayEnabled = true//input.bool(true, "Enabled", group = "Backtesting Dashboard", display = display.none)
backtestingLocation = "Top Center"//input.string("Top Center", "Position", options = ["Top Right", "Right Center", "Top Center"], group = "Backtesting Dashboard", display = display.none)
fillBackgrounds = true//input.bool(true, "Fill Backgrounds", group = "Backtesting Dashboard", display = display.none)
screenerColor = #1B1F2B//input.color(#1B1F2B, 'Background', inline = "1", group = 'Backtesting Dashboard', display = display.none)

i_textColor = mau_den//input.color(mau_den, "Text", inline = "colors", group = "Visuals")

highColor = mau_trong_suot //up_color//not i_an_thu_gon ? up_color : mau_trong_suot//input.color(up_color, "Buy", inline = "colors", group = "Visuals")
lowColor = mau_trong_suot //dn_color//not i_an_thu_gon ? dn_color : mau_trong_suot//input.color(dn_color, "Sell", inline = "colors", group = "Visuals")
textColor = mau_trong_suot //i_textColor//not i_an_thu_gon ? i_textColor : mau_trong_suot

highColor_an = i_an_thu_gon ? mau_trong_suot : mau_trong_suot
lowColor_an = i_an_thu_gon ? mau_trong_suot : mau_trong_suot
textColor_an = i_an_thu_gon ? mau_trong_suot : mau_trong_suot

n_tool_vithe = i_an_thu_gon ? 1 : 500

//buyAlertEnabled = input.bool(true, "Buy Signal", inline = "BS", group = "Alerts")
//sellAlertEnabled = input.bool(true, "Sell Signal", inline = "BS", group = "Alerts")
//tpAlertEnabled = input.bool(true, "Take-Profit Signal", inline = "TS", group = "Alerts")
//slAlertEnabled = input.bool(true, "Stop-Loss Signal ", inline = "TS", group = "Alerts")

buyAlertTick = false, float en_price_buy = na, float sl_price_buy = na, float tp_price_buy = na
tpbuyAlertTick = false
slbuyAlertTick = false

sellAlertTick = false, float en_price_sell = na, float sl_price_sell = na, float tp_price_sell = na
tpsellAlertTick = false
slsellAlertTick = false

chuan_bi_buy_loc = false, chuan_bi_sell_loc = false

dca_alert = false
float dca_price = na

var n_tp = 0
var n_sl = 0
var n_sl_lientiep = 0

//==============================================================
// Khoanh vùng thời gian dc vẽ signal, dc alert, dc thong ke
//==============================================================

tz = "Asia/Ho_Chi_Minh"

isNewWeek = ta.change(weekofyear(time, tz)) != 0

dow = dayofweek(time, tz)

isMonToFri = syminfo.ticker == 'XAUUSD' ? dow >= dayofweek.monday and dow <= dayofweek.friday : true // từ thứ 2 đến thứ 6 là vàng, các mã khác đánh hết


// count n losetrade

int new_lose_trades = 0
bool new_lose_trades_long = false
bool new_lose_trades_short = false

var bool baned_long_var = false
var bool baned_short_var = false

type Sweep
    int startTime
    int endTime
    string side
    float price

type TurtleSoup
    string state
    int startTime

    int lastHour = na
    float lastHourHigh = na
    float lastHourLow = na
    Sweep brokenSweep = na
    float slTarget
    float tpTarget
    string entryType
    int entryTime
    int exitTime
    float entryPrice
    float exitPrice
    int dayEndedBeforeExit


var lineX = array.new<line>()
var boxlineX = array.new<box>()
var boxX = array.new<box>()
var labelX = array.new<label>()
var labelXXX = array.new<label>()

var ar_line = array.new_line()
var ar_label = array.new_label()


var TurtleSoup[] tsList = array.new<TurtleSoup>(0)
var TurtleSoup lastTS = na

atr = ta.atr(atrLen)

diffPercent (float val1, float val2) =>
    (math.abs(val1 - val2) / val2) * 100.0

getPosition (positionText) =>
    if positionText == "Top Right"
        position.top_right
    else if positionText == "Top Center"
        position.top_center
    else if positionText == "Right Center"
        position.middle_right
    else if positionText == "Left Center"
        position.middle_left
    else if positionText == "Bottom Center"
        position.bottom_center
    else if positionText == "Middle Center"
        position.middle_center

backendJson(string _action, float _entry, float _sl, float _tp, string _role, float _dcaPrice, bool _sendDcaLimit) =>
    rolePart = str.length(_role) > 0 ? ",\"signal_role\":\"" + _role + "\"" : ""
    dcaPart = not na(_dcaPrice) ? ",\"dca_price\":" + str.tostring(_dcaPrice, format.mintick) : ""
    dcaLimitPart = _sendDcaLimit and not na(_dcaPrice) ? ",\"dca_entry_type\":\"limit\",\"dca_order_type\":\"limit\",\"dca_limit_price\":" + str.tostring(_dcaPrice, format.mintick) : ""
    alertId = i_backend_signal_id + "-" + syminfo.ticker + "-" + timeframe.period + "-" + str.tostring(time) + "-" + _action + (str.length(_role) > 0 ? "-" + _role : "")
    alertNow = na(timenow) ? time : timenow
    "{\"secret\":\"" + i_backend_secret + "\",\"schema_version\":2,\"contract_version\":2,\"alert_time_ms\":" + str.tostring(alertNow) + ",\"bar_time_ms\":" + str.tostring(time) + ",\"alert_id\":\"" + alertId + "\",\"signal_id\":\"" + i_backend_signal_id + "\",\"bot_code\":\"" + i_backend_bot_code + "\",\"action\":\"" + _action + "\",\"symbol\":\"" + i_backend_symbol + "\",\"tv_symbol\":\"" + syminfo.tickerid + "\",\"timeframe\":\"" + timeframe.period + "\",\"entry_price\":" + str.tostring(_entry, format.mintick) + ",\"stop_loss\":" + str.tostring(_sl, format.mintick) + ",\"take_profit\":" + str.tostring(_tp, format.mintick) + rolePart + dcaPart + dcaLimitPart + "}"

tfInMin = timeframe.in_seconds() / 60

//#region Liqs
if timeframe.in_seconds(higherTimeframe) <= timeframe.in_seconds()
    runtime.error("Khung lớn hơn nội bộ phải cao hơn khung chart hiện tại.")
int htfMins = timeframe.in_seconds(higherTimeframe) / 60
int barLength = htfMins / tfInMin
float high12 = ta.highest(barLength)
float low12 = ta.lowest(barLength)
float highMSS = ta.highest(mssOffset)
float lowMSS = ta.lowest(mssOffset)
int lastHourTime = time[barLength]
//#endregion

//#region Turtle Soup
var highBreaks = 0
var lowBreaks = 0

if bar_index > last_bar_index - maxDistanceToLastBar
    if true
        // Find Session Start
        createNewTS = true
        if not na(lastTS)
            if na(lastTS.exitPrice)
                createNewTS := false // Don't enter if a trade is already entered
                
        if createNewTS
            newTS = TurtleSoup.new("Waiting For Liquidity Break", time)
            newTS.lastHourHigh := high12
            newTS.lastHourLow := low12
            newTS.lastHour := lastHourTime
            tsList.unshift(newTS)
            lastTS := newTS
            log.info("New Turtle Soup")

        if not na(lastTS)
            // Find Liquidity Breaks
            if lastTS.state == "Waiting For Liquidity Break"
                log.info("Wait For Liq Grab")
                if time > lastTS.startTime
                    if (breakoutMethod == "Close" ? close : low) < lastTS.lastHourLow
                        log.info("Sellside Liq Grab")
                        if entryMethod == "Classic" or highBreaks > lowBreaks
                            lastTS.brokenSweep := Sweep.new(lastTS.lastHour, time, "Sellside", lastTS.lastHourLow)
                            lastTS.entryType := "Long"
                        else if highBreaks <= lowBreaks
                            //lastTS.brokenSweep := Sweep.new(lastTS.lastHour, time, "Buyside", lastTS.lastHourHigh)
                            lastTS.brokenSweep := Sweep.new(lastTS.lastHour, time, "Sellside", lastTS.lastHourLow)
                            lastTS.entryType := "Short"

                        lastTS.state := "Waiting For Execution"
                    
                    else if (breakoutMethod == "Close" ? close : high) > lastTS.lastHourHigh
                        log.info("Buyside Liq Grab")
                        if entryMethod == "Classic" or highBreaks <= lowBreaks
                            lastTS.brokenSweep := Sweep.new(lastTS.lastHour, time, "Buyside", lastTS.lastHourHigh)
                            lastTS.entryType := "Short"
                        else if highBreaks > lowBreaks
                            //lastTS.brokenSweep := Sweep.new(lastTS.lastHour, time, "Sellside", lastTS.lastHourLow)
                            lastTS.brokenSweep := Sweep.new(lastTS.lastHour, time, "Buyside", lastTS.lastHourHigh)
                            lastTS.entryType := "Long"
                        lastTS.state := "Waiting For Execution"
            // Execute
            if lastTS.state == "Waiting For Execution"
                if time > lastTS.brokenSweep.endTime
                    log.info("MSS Execution")
                    if lastTS.entryType == "Short"
                        if (breakoutMethod == "Close" ? close : low) < lowMSS[1]// and not baned_short_var[1]
                            sellAlertTick := true
                            lastTS.state := "Entry Taken"
                            lastTS.entryTime := time
                            lastTS.entryPrice := (breakoutMethod == "Close" ? close : lowMSS[1])
                            en_price_sell := (breakoutMethod == "Close" ? close : lowMSS[1])
                            if tpslMethod == "Fixed"
                                lastTS.slTarget := lastTS.entryPrice  + use_SL//* (1 + slPercent / 100.0)
                                lastTS.tpTarget := lastTS.entryPrice - use_TP//* (1 - tpPercent / 100.0)
                                sl_price_sell := lastTS.entryPrice  + use_SL//* (1 + slPercent / 100.0)
                                tp_price_sell := lastTS.entryPrice - use_TP//* (1 - tpPercent / 100.0)
                            else
                                lastTS.slTarget := highMSS + atr * slATRMult
                                lastTS.tpTarget := lastTS.entryPrice - (math.abs(lastTS.entryPrice - lastTS.slTarget) * RR)
                    else // Long
                        if (breakoutMethod == "Close" ? close : high) > highMSS[1]// and not baned_long_var[1]
                            buyAlertTick := true
                            lastTS.state := "Entry Taken"
                            lastTS.entryTime := time
                            lastTS.entryPrice := (breakoutMethod == "Close" ? close : highMSS[1])
                            en_price_buy := (breakoutMethod == "Close" ? close : highMSS[1])
                            if tpslMethod == "Fixed"
                                lastTS.slTarget := lastTS.entryPrice - use_SL//* (1 - slPercent / 100.0)
                                lastTS.tpTarget := lastTS.entryPrice + use_TP//* (1 + tpPercent / 100.0)
                                sl_price_buy := lastTS.entryPrice - use_SL//* (1 - slPercent / 100.0)
                                tp_price_buy := lastTS.entryPrice + use_TP//* (1 + tpPercent / 100.0)
                            else
                                lastTS.slTarget := lowMSS - atr * slATRMult
                                lastTS.tpTarget := lastTS.entryPrice + (math.abs(lastTS.entryPrice - lastTS.slTarget) * RR)
    
    // Entry Taken
    if not na(lastTS)
        if lastTS.state == "Entry Taken"
            log.info("Entry Taken")
            if tpslMethod == "Fixed"
                // Take Profit
                if lastTS.entryType == "Long" and high - lastTS.entryPrice >= use_TP and time > lastTS.entryTime//((high / lastTS.entryPrice) - 1) * 100 >= tpPercent
                    if not baned_long_var[1]
                        tpbuyAlertTick := true
                        //alert("🔔 Chạm TP Buy" + "\n" + "⏰ Time: " + str.format_time(time, "dd-MM-yyyy HH:mm", "UTC+7"), alert.freq_once_per_bar)
                    lastTS.exitPrice := lastTS.entryPrice + use_TP //* (1 + tpPercent / 100.0)
                    lastTS.exitTime := time
                    lastTS.state := "Take Profit"
                    highBreaks += 1
                if lastTS.entryType == "Short" and lastTS.entryPrice - low >= use_TP and time > lastTS.entryTime//((low / lastTS.entryPrice) - 1) * 100 <= -tpPercent
                    if not baned_short_var[1]
                        tpsellAlertTick := true
                        //alert("🔔 Chạm TP Sell" + "\n" + "⏰ Time: " + str.format_time(time, "dd-MM-yyyy HH:mm", "UTC+7"), alert.freq_once_per_bar)
                    lastTS.exitPrice := lastTS.entryPrice - use_TP//* (1 - tpPercent / 100.0)
                    lastTS.exitTime := time
                    lastTS.state := "Take Profit"
                    lowBreaks += 1
                
                // Stop Loss
                if lastTS.entryType == "Long" and lastTS.entryPrice - low >= use_SL and time > lastTS.entryTime//((low / lastTS.entryPrice) - 1) * 100 <= -slPercent
                    if not baned_long_var[1]
                        slbuyAlertTick := true
                        //alert("🔔 Chạm SL Buy" + "\n" + "⏰ Time: " + str.format_time(time, "dd-MM-yyyy HH:mm", "UTC+7"), alert.freq_once_per_bar)
                    lastTS.exitPrice := lastTS.entryPrice - use_SL//* (1 - slPercent / 100.0)
                    lastTS.exitTime := time
                    lastTS.state := "Stop Loss"
                    highBreaks -= 1
                if lastTS.entryType == "Short" and high - lastTS.entryPrice >= use_SL and time > lastTS.entryTime//((high / lastTS.entryPrice) - 1) * 100 >= slPercent
                    if not baned_short_var[1]
                        slsellAlertTick := true
                        //alert("🔔 Chạm SL Sell" + "\n" + "⏰ Time: " + str.format_time(time, "dd-MM-yyyy HH:mm", "UTC+7"), alert.freq_once_per_bar)
                    lastTS.exitPrice := lastTS.entryPrice + use_SL//* (1 + slPercent / 100.0)
                    lastTS.exitTime := time
                    lastTS.state := "Stop Loss"
                    lowBreaks -= 1

//#endregion

//#region Render Turtle Soups

renderTopSL = false
renderBottomSL = false
renderTopTP = false
renderBottomTP = false

if not na(lastTS)
    if lastTS.state == "Stop Loss" and time > lastTS.entryTime
        if lastTS.entryType == "Long"
            renderBottomSL := true
        else
            renderTopSL := true
        lastTS.state := "Done"
    if lastTS.state == "Take Profit" and time > lastTS.entryTime
        if lastTS.entryType == "Long"
            renderTopTP := true
        else
            renderBottomTP := true
        lastTS.state := "Done"

//plotchar(renderTopSL, "", char = "❌", location = location.abovebar, color = color.red, textcolor = textColor, text = "SL", size = size.tiny)
//plotchar(renderBottomSL, "", char = "❌", location = location.belowbar, color = color.red, textcolor = textColor, text = "SL", size = size.tiny)
