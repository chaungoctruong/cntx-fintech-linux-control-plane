//        alert("Stop-Loss Signal")

//txt_alert_3 = 
// nen_xanh ? "🔔 " + syminfo.tickerid + "\n" + "🟢 BUY" + "\n" + "▶️ EN: " + str.tostring(close, format.mintick) + "\n" + "❌ SL: " + str.tostring(low, format.mintick) + "\n" + "✅ TP: " + str.tostring(high, format.mintick) + "\n" + "⏰ Time: " + str.format_time(time, "dd-MM-yyyy HH:mm", "UTC+7") : 
// nen_do ? "🔔 " + syminfo.tickerid + "\n" + "🔴 SELL" + "\n" + "▶️ EN: " + str.tostring(close, format.mintick) + "\n" + "❌ SL: " + str.tostring(high, format.mintick) + "\n" + "✅ TP: " + str.tostring(low, format.mintick) + "\n" + "⏰ Time: " + str.format_time(time, "dd-MM-yyyy HH:mm", "UTC+7") : na
 


//if not initRun and buyAlertTick
//    var table t3 = table.new(position = position.bottom_right, columns = 2, rows = 4,
//     bgcolor = mau_trong_suot,
//     frame_color = color.rgb(0, 0, 0), frame_width = 1, border_color = color.rgb(0, 0, 0), border_width = 1, force_overlay = true)

//    table.cell(t3, 0, 0, "", bgcolor = mau_trang, text_size = size.small)
//    table.cell(t3, 0, 1, "en = " + str.tostring(lastTS.entryPrice, format.mintick), bgcolor = mau_trang, text_size = size.small)
//    table.cell(t3, 0, 2, "sl = " + str.tostring(lastTS.entryPrice - use_SL, format.mintick), bgcolor = mau_trang, text_size = size.small)
