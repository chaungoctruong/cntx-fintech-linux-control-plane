const bool DEBUG_2 = false
const int maxDistanceToLastBar_2 = 5000
const int labelCooldown_2 = 8
const int KDELimit_2 = 300

//"RSI (Kernel Optimized) | Flux Charts conver v6", overlay = true, max_labels_count = 500)

rsiLengthInput = 14//input.int(14, minval = 1, title="RSI Length", group="RSI Settings")
rsiSourceInput = close//input.source(close, "Source", group="RSI Settings")

highPivotLen = 21//input.int(21,  "High Pivot Length", minval = 1, group = "Pivots", display = display.none)
lowPivotLen = 21//input.int(21, "Low Pivot Length", minval = 1, group = "Pivots", display = display.none)
realPivotLabels = DEBUG_2 ? false : false//input.bool(false, "[DBG] Real Pivot Labels", group = "Pivots") : false
kdePivotLabels = DEBUG_2 ? false : false//input.bool(false, "[DBG] KDE Pivot Labels", group = "Pivots") : false

activationThresholdStr = "Medium"//input.string("Medium", "Activation Threshold", options = ["High", "Medium", "Low"], group = "KDE", tooltip = "Determines the amount of arrows shown. Higher options will result in more arrows being rendered.")
string KDEKernel = "Gaussian"//input.string("Gaussian", "Kernel", options=['Uniform', 'Gaussian', 'Sigmoid'], group = "KDE", tooltip = "The kernel function for KDE calculation. Gaussian is a commonly used kernel and is based on normal distribution.")
float KDEBandwidth = 2.71828//input.float(2.71828, "Bandwidth", group = "KDE", tooltip = "This setting sets the smoothness of the KDE function output.")
int KDEStep = 100//input.int(100, "Nº Bins", minval = 1, group = "KDE", tooltip = "The number of elements the KDE Probability array will have. Higher settings will result in greater precision.")
activationThreshold = DEBUG_2 ? 0.25 : 0.25//input.float(0.25, "[DBG] Activation Threshold", group = "KDE") : 0.25
if not DEBUG_2
    activationThreshold := (activationThresholdStr == "High" ? 0.4 : activationThresholdStr == "Medium" ? 0.25 : 0.15)
probMode = DEBUG_2 ? "Sum" : "Sum"//input.string("Sum", '[DBG] Probability Mode', options = ["Sum", "Nearest"], group = "KDE") : "Sum"
minPadding = DEBUG_2 ? false : false//input.bool(false, '[DBG] KDE Min Padding', group = "KDE") : false

tableEnabled = true//input.bool(true, "Dashboard", group = "Dashboard", display = display.none)
tableLocation = "Top Right"//input.string("Top Right", "Position", options = ["Top Right", "Top Center", "Right Center", "Middle Center", "Left Center", "Bottom Center"], group = "Dashboard", display = display.none)
screenerColor_2 = #1B1F2B//input.color(#1B1F2B, 'Background',  group = 'Dashboard', display = display.none)
frameColor = color.rgb(255, 255, 255)//input.color(color.rgb(255, 255, 255), 'Frame', group = 'Dashboard', display = display.none)
borderColor = color.rgb(255, 255, 255)//input.color(color.rgb(255, 255, 255), 'Border', group = 'Dashboard', display = display.none)
textColor_2DB = color.white//input.color(color.white, 'Text', group = 'Dashboard', display = display.none)
fillBackgrounds_2 = true//input.bool(true, "Fill Backgrounds", group = "Dashboard", display = display.none)

textColor_2 = color.white//input.color(color.white, 'Text', group = 'Style', inline = "col", display = display.none)
