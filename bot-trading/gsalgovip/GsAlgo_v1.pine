KDELabelsEnabled = true//input.bool(true, "KDE Labels", group = "Style")

rsi = ta.rsi(rsiSourceInput, rsiLengthInput)

//#region KDE
gaussian (float distance, float bandwidth = 1.0) => 1.0 / math.sqrt(2.0 * math.pi) * math.pow(math.e, -0.5 * math.pow(distance / bandwidth, 2.0))
uniform (float distance, float bandwidth = 1.0) => (math.abs(distance) > bandwidth) ? 0.0 : 0.5
sigmoid (float distance, float bandwidth = 1.0) => 2.0 / math.pi * (1.0 / (math.pow(math.e, (distance / bandwidth)) + math.pow(math.e, -(distance / bandwidth))))

kde (array<float> arr, string kernel, float bandwidth, int steps) =>
    arrSize = arr.size()
    arrRange = arr.range()
    arrMin = arr.min() - (minPadding ? (arrRange / 2.0) : 0)
    stepCount = arrRange / steps
    
    densityRange = array.new<float>(steps * 2)
    for i = 0 to (steps * 2) - 1
        densityRange.set(i, arrMin + i * stepCount)
    
    xArr = array.new<float>()
    yArr = array.new<float>()
    for i = 0 to densityRange.size() - 1
        float temp = 0
        for j = 0 to arr.size() - 1
            switch KDEKernel
                "Gaussian" => temp += gaussian(densityRange.get(i) - arr.get(j), 1.0 / bandwidth)
                "Uniform" => temp += uniform(densityRange.get(i) - arr.get(j), 1.0 / bandwidth)
                "Sigmoid" => temp += sigmoid(densityRange.get(i) - arr.get(j), 1.0 / bandwidth)
        
        xArr.push(densityRange.get(i))
        yArr.push(1.0 / arrSize * temp)
    [xArr, yArr]
//#endregion

//#region Pivots

prefixSum (array<float> arr, int l, int r) =>
    arr.get(r) - (l == 0 ? 0 : arr.get(l - 1))

float MidKDEHigh = na
float MidKDELow = na

var array<float> KDEHighX = na
var array<float> KDEHighY = na
var array<float> KDEHighYSum = array.new<float>()

var array<float> KDELowX = na
var array<float> KDELowY = na
var array<float> KDELowYSum = array.new<float>()

highPivot = ta.pivothigh(highPivotLen, highPivotLen)
lowPivot = ta.pivotlow(lowPivotLen, lowPivotLen)

var highPivotRSIs = array.new<float>()
var lowPivotRSIs = array.new<float>()

if not na(highPivot)
    if highPivotRSIs.size() > KDELimit_2
        highPivotRSIs.remove(0)
    highPivotRSIs.push(rsi[highPivotLen])

    [KDEHighX1, KDEHighY1] = kde(highPivotRSIs, KDEKernel, KDEBandwidth, KDEStep)
    KDEHighX := KDEHighX1
    KDEHighY := KDEHighY1
    
    KDEHighYSum.clear()
    temp = 0.0
    for i = 0 to KDEHighY.size() - 1
        temp += KDEHighY.get(i)
        KDEHighYSum.push(temp)

    MidKDEHigh := array.get(KDEHighX, array.indexof(KDEHighY, array.max(KDEHighY)))

if not na(lowPivot)
    if lowPivotRSIs.size() > KDELimit_2
        lowPivotRSIs.remove(0)
    lowPivotRSIs.push(rsi[lowPivotLen])

    [KDELowX1, KDELowY1] = kde(lowPivotRSIs, KDEKernel, KDEBandwidth, KDEStep)
    KDELowX := KDELowX1
    KDELowY := KDELowY1

    KDELowYSum.clear()
    temp = 0.0
    for i = 0 to KDELowY.size() - 1
        temp += KDELowY.get(i)
        KDELowYSum.push(temp)

    MidKDELow := array.get(KDELowX, array.indexof(KDELowY, array.max(KDELowY)))
//#endregion

//#region KDE Optimization
f_lin_interpolate(float x0, float x1, float y0, float y1, float x) =>
    y0 + (x - x0) * (y1 - y0) / (x1 - x0)

float lowProb = na
float maxLowProb = na
float highProb = na
float maxHighProb = na

if last_bar_index - maxDistanceToLastBar_2 < bar_index
    if highPivotRSIs.size() > 0
        highXIndexL = array.binary_search_leftmost(KDEHighX, rsi)
        highXIndexR = math.min(array.binary_search_rightmost(KDEHighX, rsi), KDEHighX.size() - 1)
        nearestIndex = (math.abs(rsi - KDEHighX.get(highXIndexL)) < math.abs(rsi - KDEHighX.get(highXIndexR))) ? highXIndexL : highXIndexR
        if probMode == "Nearest"
            highProb := KDEHighY.get(nearestIndex)
            maxHighProb := array.max(KDEHighY)
        else if probMode == "Sum"
            highProb := prefixSum(KDEHighYSum, 0, nearestIndex)
    
    if lowPivotRSIs.size() > 0
        lowXIndexL = array.binary_search_leftmost(KDELowX, rsi)
        lowXIndexR = math.min(array.binary_search_rightmost(KDELowX, rsi), KDELowX.size() - 1)
        nearestIndex = (math.abs(rsi - KDELowX.get(lowXIndexL)) < math.abs(rsi - KDELowX.get(lowXIndexR))) ? lowXIndexL : lowXIndexR
        if probMode == "Nearest"
            lowProb := KDELowY.get(nearestIndex)
            maxLowProb := array.max(KDELowY)
        else if probMode == "Sum"
            lowProb := prefixSum(KDELowYSum, nearestIndex, KDELowYSum.size() - 1)

        if DEBUG_2 and barstate.islastconfirmedhistory
            for i = 0 to KDELowX.size() - 1
                curX = KDELowX.get(i)
                curY = KDELowY.get(i)
                log.info(str.tostring(curX) + " = " + str.tostring(curY))
            log.info("High Y Sum " + str.tostring(KDEHighY.sum()))

diffToHighKDE = math.abs(rsi - MidKDEHigh)
diffToLowKDE = math.abs(rsi - MidKDELow)
//#endregion

//#region Draw Pivots
color curColor = na
if (not na(KDELowY)) and (not na(KDEHighY))
    if probMode == "Nearest"
        if math.abs(lowProb - maxLowProb) < activationThreshold / 50.0
            curColor := bullishColor
        if math.abs(highProb - maxHighProb) < activationThreshold / 50.0
            curColor := bearishColor
    else if probMode == "Sum"
        if lowProb > KDELowY.sum() * (1.0 - activationThreshold)
            curColor := bullishColor
        else if highProb > KDEHighY.sum() * (1.0 - activationThreshold)
            curColor := bearishColor
//barcolor(curColor)

atr_2 = ta.atr(50)

plotarrow(i_congcu_daochieu and curColor == bullishColor and barstate.isconfirmed ? 1 : na, "Bullish Arrows", color.new(bullishColor, 70), color.new(bullishColor, 70), minheight = 20, maxheight = 20)
plotarrow(i_congcu_daochieu and curColor == bearishColor and barstate.isconfirmed ? -1 : na, "Bearish Arrows", color.new(bearishColor, 70), color.new(bearishColor, 70), minheight = 20, maxheight = 20)

plotarrow((i_congcu_daochieu and na(curColor) and curColor[1] == bullishColor and barstate.isconfirmed) ? 1 : na, "Possible Bullish Pivot", bullishColor, bullishColor, minheight = 20, maxheight = 20)
plotarrow((i_congcu_daochieu and na(curColor) and curColor[1] == bearishColor and barstate.isconfirmed) ? -1 : na, "Possible Bearish Pivot", bearishColor, bearishColor, minheight = 20, maxheight = 20)

alertcondition(na(curColor) and curColor[1] == bullishColor and barstate.isconfirmed, "Possible Bullish Pivot")
alertcondition(na(curColor) and curColor[1] == bearishColor and barstate.isconfirmed, "Possible Bearish Pivot")

//#endregion


//
//
//
//
//


//--------------------------------------------------------------------------------------------------------------------------
// Thuật toán cũ đã cho tàn hình hết => từ đoạn này sẽ lọc ra trong những cái tàn hình đó để vẽ lại, thống kê lại, alert lại
//--------------------------------------------------------------------------------------------------------------------------

//"Trade Object EN SL TP (LineFill)", overlay = true, max_lines_count = 500, max_labels_count = 500, max_linefill_count = 500)

//==================================================

//==================================================
// INPUT
//==================================================
//maxTrades = input.int(5, "Số trade hiển thị", minval = 1)
//showAll   = input.bool(false, "Hiển thị tất cả trade")

colEN = up_color
colSL = dn_color
colTP = up_color
colDCA = mau_tim

colSLFill = dn_color
colTPFill = up_color

//==============================
// MOCK SIGNAL – THAY BẰNG CODE CỦA MÀY
//==============================
sigLong  = buy_loc or buy_in_baned_zone                          // signal long
sigShort = sell_loc or sell_in_baned_zone                        // signal short

enLong = buy_loc ? en_price_buy : buy_in_baned_zone ? en_buy_in_baned_zone : na                              // entry long
slLong = buy_loc ? sl_price_buy : buy_in_baned_zone ? sl_buy_in_baned_zone : na                              // sl long
tpLong = buy_loc ? tp_price_buy : buy_in_baned_zone ? tp_buy_in_baned_zone : na                              // tp long

enShort = sell_loc ? en_price_sell : sell_in_baned_zone ? en_sell_in_baned_zone : na                          // entry short
slShort = sell_loc ? sl_price_sell : sell_in_baned_zone ? sl_sell_in_baned_zone : na                          // sl short
tpShort = sell_loc ? tp_price_sell : sell_in_baned_zone ? tp_sell_in_baned_zone : na                          // tp short

//==================================================
// TYPE
//==================================================
type TradeObj
    bool  isLong
    bool  active
    int   startBar

    float en
    float sl
    float tp

    line      lnEn
    line      lnSl
    line      lnTp
    linefill  lfSL
    linefill  lfTP

    label lbSig
    label lbEn
    label lbSl
    label lbTp

    float dca
    line lnDca
    label lbDca
    bool  active_dca
    
    
    

//==================================================
// METHOD – INIT
//==================================================
method init(TradeObj this) =>
    this.lnEn := line.new(this.startBar, this.en, bar_index, this.en, color = colEN, width = 2)
    this.lnSl := line.new(this.startBar, this.sl, bar_index, this.sl, color = colSL)
    this.lnTp := line.new(this.startBar, this.tp, bar_index, this.tp, color = colTP)

    this.lfSL := linefill.new(this.lnEn, this.lnSl, color.new(colSLFill, 93))
    this.lfTP := linefill.new(this.lnEn, this.lnTp, color.new(colTPFill, 93))

    this.lbSig := label.new(this.startBar, this.sl,
         this.isLong ? "BUY" : "SELL",
         style = this.isLong ? label.style_label_up : label.style_label_down,
         textcolor = mau_trong_suot,
         color = mau_trong_suot,
         size = lblSize)

    this.lbEn := label.new(bar_index, this.en, "EN: " + str.tostring(this.en, format.mintick),
         style = label.style_label_left,
         textcolor = colEN,
         color = mau_trong_suot,
         size = lblSize)

    this.lbSl := label.new(bar_index, this.sl, "SL: " + str.tostring(this.sl, format.mintick),
         style = label.style_label_left,
         textcolor = colSL,
         color = mau_trong_suot,
         size = lblSize)

    this.lbTp := label.new(bar_index, this.tp, "TP: " + str.tostring(this.tp, format.mintick),
         style = label.style_label_left,
         textcolor = colTP,
         color = mau_trong_suot,
         size = lblSize)

    this.dca := (this.en + this.sl) / 2

//==================================================
// METHOD – UPDATE
//==================================================
method update(TradeObj this) =>
    if this.active
        line.set_x2(this.lnEn, bar_index)
        line.set_x2(this.lnSl, bar_index)
        line.set_x2(this.lnTp, bar_index)

        label.set_x(this.lbEn, bar_index)
        label.set_x(this.lbSl, bar_index)
        label.set_x(this.lbTp, bar_index)

    in_f_dca_alert = false
    float in_f_price = na    
    if this.active and this.active_dca == false and this.startBar != bar_index
        if (this.isLong and low < this.dca and low > this.sl) or (not this.isLong and high > this.dca and high < this.sl)
            this.lnDca := line.new(this.startBar, this.dca, bar_index, this.dca, color = colDCA)
            this.lbDca := label.new((this.startBar + bar_index) / 2, this.dca,
                             this.isLong ? "\n\nDCA - " + str.tostring(this.dca, format.mintick) : "DCA - " + str.tostring(this.dca, format.mintick) + '\n\n',
                             style = label.style_label_center,
                             textcolor = colDCA,
                             color = mau_trong_suot,
                             size = lblSize)
            this.active_dca := true
            in_f_dca_alert := true
            in_f_price := this.dca
    if this.active and this.active_dca == true
        line.set_x2(this.lnDca, bar_index)
        label.set_x(this.lbDca, (this.startBar + bar_index) / 2)
    [in_f_dca_alert, in_f_price]
            

//==================================================
// METHOD – CHECK EXIT
//==================================================
method checkExit(TradeObj this) =>
    if this.active
        hitSL = this.isLong ? low <= this.sl : high >= this.sl
        hitTP = this.isLong ? high >= this.tp : low <= this.tp

        if hitSL or hitTP
            this.active := false
      

//==================================================
// ARRAY
//==================================================
var array<TradeObj> trades = array.new<TradeObj>()

//==================================================
// CREATE TRADE
//==================================================
createTrade(_isLong, _en, _sl, _tp) =>
    t = TradeObj.new(_isLong, true, bar_index, _en, _sl, _tp,
         na, na, na, na, na, na, na, na, na, na, na, na, false)
    t.init()
    array.push(trades, t)

f_delete_lines(ar_a) =>
    if array.size(ar_a) > 0 
        for i = 0 to array.size(ar_a) - 1 
            line.delete(array.get(ar_a, i))
        array.clear(ar_a)

f_delete_labels(ar_a) =>
    if array.size(ar_a) > 0 
        for i = 0 to array.size(ar_a) - 1 
            label.delete(array.get(ar_a, i))
        array.clear(ar_a)

f_delete_linefill(ar_a) =>
    if array.size(ar_a) > 0 
        for i = 0 to array.size(ar_a) - 1 
            linefill.delete(array.get(ar_a, i))
        array.clear(ar_a)



//==================================================
// SIGNAL HANDLE
//==================================================
if isNewWeek
    // 1️⃣ reset biến đếm
    n_sl := 0
    n_tp := 0

    // 2️⃣ xóa toàn bộ object vẽ
    f_delete_lines(line.all)
    f_delete_labels(label.all)
    f_delete_linefill(linefill.all)

    // 3️⃣ xử lý mảng trade
    if array.size(trades) > 0
        array.clear(trades)


if sigLong and isMonToFri
    createTrade(true, enLong, slLong, tpLong)

if sigShort and isMonToFri
    createTrade(false, enShort, slShort, tpShort)

//==================================================
// LIMIT OBJECT COUNT
//==================================================
if i_an_thu_gon and array.size(trades) > 0
    while array.size(trades) > 1
        old = array.shift(trades)
        line.delete(old.lnEn)
        line.delete(old.lnSl)
        line.delete(old.lnTp)
        linefill.delete(old.lfSL)
        linefill.delete(old.lfTP)
        label.delete(old.lbSig)
        label.delete(old.lbEn)
        label.delete(old.lbSl)
        label.delete(old.lbTp)
        line.delete(old.lnDca)
        label.delete(old.lbDca)
   
//==================================================
// MAIN LOOP
//==================================================
dang_buy = false
dang_sell = false

if array.size(trades) > 0
    tr = array.get(trades, array.size(trades) - 1)
    [in_loop_dca_alert, in_loop_dca_price] = update(tr)
    if tr.active
        hitSL = tr.isLong ? low <= tr.sl : high >= tr.sl
        hitTP = tr.isLong ? high >= tr.tp : low <= tr.tp
        if hitTP
            n_tp += 1
            n_sl_lientiep := 0
        else if hitSL
            n_sl += 1
            n_sl_lientiep += 1
        if tr.en > tr.sl
            dang_buy := true
        else if  tr.en < tr.sl
            dang_sell := true
    checkExit(tr)
    dca_alert := in_loop_dca_alert
    dca_price := in_loop_dca_price

//=============================================================================
// alert

if sigLong and isMonToFri
    dcaLimitLong = i_alert_5 ? (enLong + slLong) / 2 : float(na)
    alert(i_backend_alerts ? backendJson("BUY", enLong, slLong, tpLong, "", dcaLimitLong, i_alert_5) : "🟢 Buy - " + syminfo.ticker + " - " + timeframe.period + "\n" + "▶️ EN: " + str.tostring(enLong, format.mintick) + "\n" + "❌ SL:" + str.tostring(slLong, format.mintick) + "\n" + "✅ TP:" + str.tostring(tpLong, format.mintick), alert.freq_once_per_bar_close)
else if sigShort and isMonToFri
    dcaLimitShort = i_alert_5 ? (enShort + slShort) / 2 : float(na)
    alert(i_backend_alerts ? backendJson("SELL", enShort, slShort, tpShort, "", dcaLimitShort, i_alert_5) : "🔴 Sell - " + syminfo.ticker + " - " + timeframe.period + "\n" + "▶️ EN: " + str.tostring(enShort, format.mintick) + "\n" + "❌ SL:" + str.tostring(slShort, format.mintick) + "\n" + "✅ TP:" + str.tostring(tpShort, format.mintick), alert.freq_once_per_bar_close)

if not i_backend_alerts and n_tp[1] < n_tp[0] and tpbuyAlertTick and isMonToFri
    alert("🔔 Chạm TP Buy" + "\n" + "⏰ Time: " + str.format_time(time, "dd-MM-yyyy HH:mm", "UTC+7"), alert.freq_once_per_bar)
else if not i_backend_alerts and n_tp[1] < n_tp[0] and tpsellAlertTick and isMonToFri
    alert("🔔 Chạm TP Sell" + "\n" + "⏰ Time: " + str.format_time(time, "dd-MM-yyyy HH:mm", "UTC+7"), alert.freq_once_per_bar)
else if not i_backend_alerts and n_sl[1] < n_sl[0] and slbuyAlertTick and isMonToFri
    alert("🔔 Chạm SL Buy" + "\n" + "⏰ Time: " + str.format_time(time, "dd-MM-yyyy HH:mm", "UTC+7"), alert.freq_once_per_bar)
else if not i_backend_alerts and n_sl[1] < n_sl[0] and slsellAlertTick and isMonToFri
    alert("🔔 Chạm SL Sell" + "\n" + "⏰ Time: " + str.format_time(time, "dd-MM-yyyy HH:mm", "UTC+7"), alert.freq_once_per_bar)

if i_alert_5 and not i_backend_alerts and not dca_alert[1] and dca_alert and dang_buy and isMonToFri
    alert("🟢 Buy - " + syminfo.ticker + " - " + timeframe.period + "\n" + "▶️ DCA: " + str.tostring(dca_price, format.mintick) + "\n" + "❌ SL:" + str.tostring(lastTS.entryPrice - use_SL, format.mintick) + "\n" + "✅ TP:" + str.tostring(lastTS.entryPrice + use_TP, format.mintick), alert.freq_once_per_bar_close)
else if i_alert_5 and not i_backend_alerts and not dca_alert[1] and dca_alert and dang_sell and isMonToFri
    alert("🔴 Sell - " + syminfo.ticker + " - " + timeframe.period + "\n" + "▶️ DCA: " + str.tostring(dca_price, format.mintick) + "\n" + "❌ SL:" + str.tostring(lastTS.entryPrice + use_SL, format.mintick) + "\n" + "✅ TP:" + str.tostring(lastTS.entryPrice - use_TP, format.mintick), alert.freq_once_per_bar_close)




//////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////////

//#region Backtesting Dashboard

if barstate.islast and i_bang_tk_1

    var table t_1 = table.new(position = i_vitri_bang_1, columns = 3, rows = 15, bgcolor = mau_trong_suot,
     frame_color = color.rgb(0, 0, 0), frame_width = 1, border_color = color.rgb(0, 0, 0), border_width = 1, force_overlay = true)

    table.merge_cells(t_1, 0, 0, 2, 0)
    table.cell(t_1, 0, 0, "BẢNG THỐNG KÊ", bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)//"BẢNG THỐNG KÊ"
    table.cell(t_1, 0, 1, "Tổng", bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)
    table.cell(t_1, 0, 2, "Thắng", bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)
    table.cell(t_1, 0, 3, "Thua", bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)
    //table.cell(t_1, 0, 4, "Vốn", bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)
    //table.cell(t_1, 0, 5, "Khối lượng", bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)

    table.merge_cells(t_1, 1, 1, 2, 1)
    table.cell(t_1, 1, 1, str.tostring(n_tp + n_sl), bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)
    table.cell(t_1, 1, 2, str.tostring(n_tp), bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)
    table.cell(t_1, 1, 3, str.tostring(n_sl), bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)
    //table.cell(t_1, 1, 4, str.tostring(math.round(array.avg(ar_biendo), 2)), bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)
    //table.cell(t_1, 1, 5, str.tostring(math.round(bien_do_new, 2)), bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)

    //table.cell(t_1, 2, 1, "", bgcolor = color.rgb(242, 255, 0), text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)
    table.cell(t_1, 2, 2, str.tostring(math.round(n_tp / (n_tp + n_sl) * 100, 2)) + "%", bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)
    table.cell(t_1, 2, 3, str.tostring(math.round(n_sl / (n_tp + n_sl) * 100, 2)) + "%", bgcolor = i_mau_bang_tk_1, text_size = i_size_chu_bang_tk_1, text_color = i_mau_chu_bang_tk_1, text_formatting = text.format_bold)

//#endregion
