# GsAlgoVIP .env.example
# DO NOT put real secrets here. Real values come from the platform runtime
# context per-tenant, NOT from this file.

# Platform-injected per-tenant identifiers (used only for logging / metrics).
# The bot itself does NOT do tenant routing in code.
TENANT_ID=
INSTANCE_ID=

APP_HOST=0.0.0.0
APP_PORT=8017
# Empty = platform default logs/runner/gsalgovip.log. Override only for local package runs.
LOG_PATH=

# Webhook intake path. Default = /webhook/tradingview. Platform may override
# to a tenant-scoped path (e.g. /t/<tenant_id>/webhook/tradingview) when many
# tenants share the same nginx upstream.
WEBHOOK_PATH=/webhook/tradingview

# Bot's OWN PostgreSQL DB (NOT the Linux backend core DB).
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Platform must inject this; leave EMPTY in template.
DATABASE_URL=

WEBHOOK_SECRET=

TRADING_ENABLED=false
DRY_RUN=true
POLL_INTERVAL_SEC=1

DEFAULT_VOLUME=0.01
SYMBOL_MAP=
MAX_SPREAD_POINTS=0
MAX_ENTRY_DRIFT_POINTS=0
MAX_SLIPPAGE_POINTS=30

MT5_TERMINAL_PATH=
MT5_LOGIN=0
MT5_PASSWORD=
MT5_SERVER=
MT5_MAGIC=0

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
