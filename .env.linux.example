# LOCAL COMPOSE COMPATIBILITY ONLY
# File nay chi dung lam baseline cho `docker-compose.yml` tai repo root.
# Day khong phai source of truth cho PM2/systemd handoff cua control plane.
# Production handoff active nen bat dau tu `backend_ai/backend/.env.control-plane.example`.

APP_ENV=development
DRY_RUN=1
BACKEND_PORT=8001
PUBLIC_BASE_URL=http://127.0.0.1:8001

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=spider_dev
POSTGRES_PASSWORD=spider_dev_only_change_me
POSTGRES_DB=spider_dev

# Docker-compose service DNS. This only works from containers on the Linux
# compose network; do not copy this value to an external Windows runner.
REDIS_URL=redis://redis:6379/0
REDIS_WRITE_URL=redis://redis:6379/0
REDIS_READ_URL=

# External Windows runner note:
# - current Windows runner reads REDIS_URL and BOT_COMMAND_QUEUE_REDIS_URL
# - it cannot resolve the Docker hostname `redis`
# - use a routable private/public Redis host with auth, for example:
#   REDIS_URL=redis://:<password>@<linux-or-redis-host>:6379/0
#   BOT_COMMAND_QUEUE_REDIS_URL=redis://:<password>@<linux-or-redis-host>:6379/0

DATA_DIR=/root/spider-ai/data
MT5_INSTANCES_DIR=/root/spider-ai/.wine/drive_c/Program Files/MetaTrader 5 Instances
MT5_TEMPLATES_ROOT=/root/spider-ai/backend_ai/backend/static/templates

APP_SECRET_KEY=dev_local_change_me_not_for_production
BACKEND_API_KEY=dev_local_backend_key_not_for_production
TELEGRAM_BOT_TOKEN=
GEMINI_API_KEY=
AI_PROVIDER=ollama
AI_CHAT_PROVIDER=ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:14b
GEMINI_MODEL=gemini-2.5-flash-lite
AI_CHAT_OLLAMA_USE_GEMINI_FOR_SEARCH=false
AI_CHAT_OLLAMA_USE_GEMINI_FOR_COMPLEX=false
AI_LOCAL_MAX_CONCURRENT=1
AI_LOCAL_QUEUE_WAIT_SEC=0.5
AI_CHAT_TIMEOUT_SEC=20
AI_CHAT_IMMEDIATE_FALLBACK_ENABLED=true
AI_CHAT_DB_MEMORY_ENABLED=true
AI_CHAT_DB_CACHE_ENABLED=true
AI_CHAT_DB_CACHE_TTL_SEC=604800
AI_CHAT_DB_GLOBAL_LEARNING_ENABLED=true
AI_CHAT_DB_LEARNED_CONTEXT_LIMIT=3
AI_CHAT_DB_LEARNED_SIMILARITY_THRESHOLD=0.42
AI_PLATFORM_KNOWLEDGE_ENABLED=true
AI_PLATFORM_KNOWLEDGE_MAX_CHUNKS=4
AI_PLATFORM_KNOWLEDGE_MIN_TRUST_LEVEL=40
AI_TRAINING_CAPTURE_ENABLED=true
AI_TRAINING_MIN_PROMPT_CHARS=6
AI_TRAINING_MAX_PROMPT_CHARS=1800
AI_TRAINING_MAX_COMPLETION_CHARS=5000
AI_TRAINING_DEFAULT_EXPORT_LIMIT=1000
AI_TRAINING_EXPORT_DIR=ops/ai/training_exports
# Legacy Ollama fallback only: OLLAMA_MODEL -> AI_MODEL -> qwen3:8b.
AI_MODEL=qwen3:8b

# Gemini is for the shared 6h morning news digest only.
AI_CARE_CAMPAIGN_ENABLED=true
AI_CARE_DRY_RUN=false
AI_CARE_INCLUDE_NEWS=true
AI_CARE_NEWS_USE_GEMINI=true
AI_CARE_MORNING_HOUR=6
AI_CARE_MORNING_WINDOW_MIN=60
AI_CARE_NEWS_MAX_LINKS=10
AI_CARE_NEWS_CACHE_TTL_SEC=1800
AI_CARE_NEWS_STALE_HOURS=720
AI_CARE_DIGEST_CACHE_TTL_SEC=86400
AI_CARE_EXTRA_TELEGRAM_IDS=
