{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "out",
  "rewrites": [
    {
      "source": "/ready",
      "destination": "http://103.90.225.53:8001/ready"
    },
    {
      "source": "/health",
      "destination": "http://103.90.225.53:8001/health"
    },
    {
      "source": "/api/v2/:path*",
      "destination": "http://103.90.225.53:8001/api/v2/:path*"
    }
  ]
}
