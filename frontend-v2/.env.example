# Mẫu biến build-time cho Mini App (Next.js).
# Sao chép: cp .env.example .env rồi chỉnh giá trị; KHÔNG commit file .env (đã gitignore).
# Mọi NEXT_PUBLIC_* được nhúng vào bundle lúc `npm run build` — đổi URL phải build lại.
# Nên build trong container Linux (xem README.md monorepo / frontend-v2/README.md).

# --- Bắt buộc cho gọi API (HTTPS khi dùng Telegram web_app / production) ---
NEXT_PUBLIC_BACKEND_URL=https://your-public-control-plane.example
NEXT_PUBLIC_API_URL=https://your-public-control-plane.example

# --- Tuỳ chọn — UI MT5 (public, không secret) ---
# Danh sách broker hiển thị "Server đang cập nhật" (phân tách dấu phẩy). Để trống = không khóa.
NEXT_PUBLIC_MT5_SERVER_PENDING_BROKERS=
# Fixed server: "Broker A=Server-A,Broker B=Server-B"
NEXT_PUBLIC_MT5_FIXED_SERVERS=

# --- Tuỳ chọn — telemetry / banner phiên bản ---
# NEXT_PUBLIC_RELEASE=1.0.0
